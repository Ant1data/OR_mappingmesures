# Copiez ce fichier en ".env" et renseignez les valeurs.
# Le fichier ".env" est ignoré par git (voir .gitignore).

# ─── Clé API OpenRadiation (OBLIGATOIRE pour fetch_data.py) ──────────────────
OR_API_KEY=your_api_key_here

# ─── Chemins (laisser vide = valeurs par défaut relatives au dossier du projet)
# BASE_DIR=
# DATA_DIR=./out
# OUTPUT_DIR=.
# MAPS_DIR=./last_frame
# VIDEOS_DIR=./videos

# ─── Nom du fichier CSV de données
# CSV_FILENAME=measurements_withoutEnclosedObject.csv

# ─── Paramètres de téléchargement API
# OR_START_DATE=2015-01-01T00:00:00Z
# OR_END_DATE=
# OR_PAGE_SIZE=5000
# OR_MAX_PAGES=0

# ─── Paramètres de filtrage des données
# START_DATE=2015-01-01
# MAX_ALTITUDE=4000
# MAX_VALUE=0.4

# ─── Paramètres vidéo
# VIDEO_DURATION_SECONDS=60
# TARGET_FPS=1
# VIDEO_FPS=2
# IMG_WIDTH=900
# IMG_HEIGHT=600
# MAP_DPI=200

# ─── Serveur Dash (OR_html_plane.py)
# DASH_HOST=127.0.0.1
# DASH_PORT=8050
# DASH_DEBUG=false

# ─── Logs
# LOG_LEVEL=WARNING
